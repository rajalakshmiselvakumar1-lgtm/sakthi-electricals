rules_version = '2';

// ============================================================
// FIRESTORE SECURITY RULES — Sakthi Electricals ERP
//
// Deploy with: firebase deploy --only firestore:rules
// (requires the Firebase CLI; see README.md "Deploying security rules")
//
// Model: any authenticated staff member (Admin or Staff role, both created
// via Firebase Auth) can read/write all shop data. Only Admins can delete
// records. This matches how a real single-location retail shop operates —
// one shared back office — while still requiring login and blocking
// public/anonymous access entirely, which the original prototype had no
// rules for at all.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Each signed-in user can read any profile doc (needed to resolve role
    // badges across the app); only an Admin or the user themself can write it.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Shared counters doc (nextProdId, nextOrdId, etc.) — nothing sensitive.
    match /settings/{docId} {
      allow read, write: if isSignedIn();
    }

    // Core business collections: any signed-in staff member can read and
    // create/update (billing and stock updates happen constantly on the
    // shop floor). Deletes are Admin-only so a junior staff account can't
    // wipe the catalog or order history.
    match /products/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /categories/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /customers/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /suppliers/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /orders/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /purchaseOrders/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /stockMovements/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /notifications/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
