# Firebase web config is intentionally NOT loaded from environment variables
# in this project — see src/firebase/init.js.
#
# Why: Firebase web API keys are not secrets. They identify your project to
# Google's servers, but all real access control happens in firestore.rules
# (this repo includes a production-ready rules file) and in Firebase
# Authentication — not by hiding the apiKey. This matches Firebase's own
# guidance and is why the config can safely stay committed in init.js.
#
# If your organization's policy still requires env-var injection (e.g. to
# swap configs between a staging and production Firebase project), copy the
# six values below into a real `.env` file, then update src/firebase/init.js
# to read them via `import.meta.env.VITE_*` instead of the hardcoded object.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
