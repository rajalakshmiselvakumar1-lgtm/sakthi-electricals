rules_version = '2';

// ============================================================
// FIREBASE STORAGE SECURITY RULES — Sakthi Electricals ERP
//
// Deploy with: firebase deploy --only storage
//
// Same access model as firestore.rules: any signed-in staff member can
// upload/read product, supplier, and business images; nothing is public.
// Uploads are capped at 5MB and restricted to image content types to stop
// someone using the shop's bucket to host arbitrary files.
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {

    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
